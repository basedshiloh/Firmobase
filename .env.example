# ─────────────────────────────────────────────────────────────
# Firmobase — root environment template
# Copy to .env (pipeline) and apps/web/.env.local (web) and fill in.
# Never commit real values.
# ─────────────────────────────────────────────────────────────

# --- Supabase (dedicated project, NOT the shared one) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres connection (for SQLAlchemy / migrations)
DATABASE_URL=postgresql+psycopg://postgres:PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres

# --- Clerk (auth) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Redis (Celery broker/result backend) ---
REDIS_URL=redis://localhost:6379/0

# --- Anthropic (AI insights, Phase 7) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- eKRS (public endpoints; details provided later) ---
EKRS_API_BASE=https://api-krs.ms.gov.pl
EKRS_RATE_LIMIT_PER_MIN=30
